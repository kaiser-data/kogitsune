#!/usr/bin/env bash
# kogitsune 🦊 — pack your kit, send the little fox off light.
# Usage:
#   kit                  interactive picker (fzf)
#   kit <name>           launch a named kit (lean|db|n8n|frontend|research|…)
#   kit <name> --dry-run resolve + show the plan, launch nothing
#   kit <name> -- ARGS   forward ARGS to `claude` (e.g. kit db -- --model opus "fix X")
#   kit ls               list kits + à la carte catalog
#   kit show <name>      show what a kit packs (no launch)
#   kit save <name> --mcp a,b --skills x,y   save a selection as a named kit
#   kit measure <name>   launch a one-shot probe; record real ctx tokens
#   kit doctor           check deps, config, auth
#   kit help
set -euo pipefail

HERE="$(cd "$(dirname "$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
LIB="$ROOT/lib"
# shellcheck source=lib/session-env.sh
source "$LIB/session-env.sh"

CONFIG="${KOGITSUNE_CONFIG:-}"
[[ -z "$CONFIG" && -f "$ROOT/kits.yaml" ]] && CONFIG="$ROOT/kits.yaml"
[[ -z "$CONFIG" && -f "./kits.yaml" ]] && CONFIG="./kits.yaml"
if [[ -z "$CONFIG" ]]; then
  CONFIG="$ROOT/examples/kits.example.yaml"
  echo "kit: no kits.yaml found — using examples/kits.example.yaml (copy it to kits.yaml to customize)" >&2
fi
MCP_ON_DEMAND="${KOGITSUNE_MCP_ON_DEMAND:-$HOME/.claude/mcp-on-demand.json}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/kogitsune"
STATE_FILE="$STATE_DIR/last-kits.json"

die() { echo "kit: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"; }
# auto-detect a project overlay (.kogitsune.yaml in cwd) merged over the base config.
# bash 3.2-safe: no mapfile; empty-array expansion guarded for `set -u`.
bc() {
  local ov=()
  [[ -f "./.kogitsune.yaml" ]] && ov=(--overlay "./.kogitsune.yaml")
  python3 "$LIB/build-config.py" --config "$CONFIG" --mcp-on-demand "$MCP_ON_DEMAND" \
    ${ov[@]+"${ov[@]}"} "$@"
}
ce() { python3 "$LIB/context-est.py" "$@"; }

remember_kit() {  # $1=kit
  mkdir -p "$STATE_DIR"
  local cwd; cwd="$(pwd)"
  local cur="{}"; [[ -f "$STATE_FILE" ]] && cur="$(cat "$STATE_FILE")"
  echo "$cur" | jq --arg k "$1" --arg d "$cwd" '.[$d] = $k' > "$STATE_FILE" 2>/dev/null || true
}

pack_weight_line() {  # $1=manifest.json
  local w; w="$(jq -r '.weight' "$1")"
  ce --weights "$w"
}

# ---- launch a resolved selection -------------------------------------------
# $1 = manifest path (already written, with mcp_config_path), rest = claude args
launch_from_manifest() {
  local manifest="$1"; shift
  jq -e '.warnings|length>0' "$manifest" >/dev/null 2>&1 && \
    jq -r '.warnings[] | "kit: warning — \(.)"' "$manifest" >&2 || true
  local mcp_path; mcp_path="$(jq -r '.mcp_config_path' "$manifest")"
  echo "🦊 $(pack_weight_line "$manifest")" >&2
  if [[ -n "${KIT_DRY_RUN:-}" ]]; then
    jq -r '"would launch:  kit=\(.kit // "(à la carte)")  mcp=\(.mcp_config.mcpServers|keys|join(","))  "
           + "plugins=\(.plugins|keys|join(","))  skills=\(.skills|map(split("/")|last)|join(","))"' "$manifest" >&2
    echo "   claude --strict-mcp-config --mcp-config $mcp_path $*" >&2
    return 0
  fi
  local mirror; mirror="$(kog_build_mirror "$manifest")"
  trap 'kog_cleanup "$mirror"' EXIT INT TERM
  [[ -n "${KIT_DEBUG:-}" ]] && { echo "kit: mirror=$mirror (KIT_DEBUG set — not auto-cleaned)" >&2; trap - EXIT; }
  CLAUDE_CONFIG_DIR="$mirror" exec claude \
    --strict-mcp-config --mcp-config "$mcp_path" "$@"
}

resolve_to_manifest() {  # writes manifest to a temp file, echoes its path. args: bc selection flags
  local out; out="$(mktemp -d "${TMPDIR:-/tmp}/kogitsune.sel.XXXXXX")"
  bc "$@" --out-dir "$out" > "$out/manifest.json"
  echo "$out/manifest.json"
}

cmd_launch() {  # $1=kit name, rest=claude passthrough (supports --dry-run)
  local kit="$1"; shift || true
  [[ "${1:-}" == "--dry-run" ]] && { export KIT_DRY_RUN=1; shift; }
  need python3; need jq
  [[ -z "${KIT_DRY_RUN:-}" ]] && need claude
  local manifest; manifest="$(resolve_to_manifest "$kit")"
  [[ -z "${KIT_DRY_RUN:-}" ]] && remember_kit "$kit"
  launch_from_manifest "$manifest" "$@"
}

cmd_measure() {  # launch a one-shot probe under the kit's mirror, record real ctx tokens
  need python3; need jq; need claude
  local kit="${1:?usage: kit measure <name>}"
  local manifest; manifest="$(resolve_to_manifest "$kit")"
  local mcp_path est; mcp_path="$(jq -r '.mcp_config_path' "$manifest")"; est="$(jq -r '.weight' "$manifest")"
  echo "kit: measuring '$kit' — launching a one-shot probe…" >&2
  local mirror; mirror="$(kog_build_mirror "$manifest")"
  trap 'kog_cleanup "$mirror"' EXIT INT TERM
  local out; out="$(CLAUDE_CONFIG_DIR="$mirror" claude -p --output-format=json --model haiku \
      'Reply with exactly: PONG' --strict-mcp-config --mcp-config "$mcp_path" 2>/dev/null)"
  kog_cleanup "$mirror"; trap - EXIT INT TERM
  local ctx; ctx="$(echo "$out" | jq -r '((.usage.input_tokens//0)+(.usage.cache_creation_input_tokens//0)+(.usage.cache_read_input_tokens//0))')"
  if ! [[ "$ctx" =~ ^[0-9]+$ ]] || [[ "$ctx" -eq 0 ]]; then
    echo "kit: measure failed — $(echo "$out" | jq -r '.result // "no output"')" >&2; return 1
  fi
  mkdir -p "$STATE_DIR"
  local mf="$STATE_DIR/measured.json" cur="{}"; [[ -f "$mf" ]] && cur="$(cat "$mf")"
  echo "$cur" | jq --arg k "$kit" --argjson c "$ctx" '.[$k]=$c' > "$mf" 2>/dev/null || true
  echo "🦊 kit '$kit':  measured = ${ctx} tokens   (catalog est ~${est} over the lean baseline)"
  echo "   recorded to $mf"
}

# resolve the file we may write kits into; seed from the example if needed
save_target() {
  if [[ -n "${KOGITSUNE_CONFIG:-}" ]]; then echo "$KOGITSUNE_CONFIG"; return; fi
  if [[ "$CONFIG" == *examples/kits.example.yaml ]]; then
    local t="./kits.yaml"
    [[ -f "$t" ]] || { cp "$CONFIG" "$t"; echo "kit: created $t from the example" >&2; }
    echo "$t"
  else echo "$CONFIG"; fi
}

cmd_save() {  # kit save <name> [--mcp a,b] [--skills x,y]
  need python3
  local name="${1:?usage: kit save <name> [--mcp a,b] [--skills x,y]}"; shift
  local mcp="" skills=""
  while [[ $# -gt 0 ]]; do
    case "$1" in --mcp) mcp="$2"; shift 2;; --skills) skills="$2"; shift 2;; *) shift;; esac
  done
  local target; target="$(save_target)"
  python3 "$LIB/build-config.py" --config "$target" --save "$name" --mcp "$mcp" --skills "$skills"
  echo "🦊 saved kit '$name' — launch it with: kit $name" >&2
}

cmd_show() {
  need python3
  local kit="${1:?usage: kit show <name>}"
  local m; m="$(bc "$kit" --dry-run)"
  echo "$m" | jq '{kit, weight, mcp: (.mcp_config.mcpServers|keys),
       plugins: (.plugins|keys), skills: (.skills|map(split("/")|last)),
       imports: (.imports|map(split("/")|last)), warnings}'
  # human pack-weight line goes to stderr so stdout stays valid JSON for piping
  echo "🦊 $(echo "$m" | jq -r .weight | xargs -I{} python3 "$LIB/context-est.py" --weights {})" >&2
}

cmd_ls() {
  need python3
  bc --list | jq -r '
    "KITS:", (.kits|to_entries[]|"  \(.key)"),
    "", "MCP (à la carte):", (.mcp|to_entries[]|"  \(.value.tag // "") \(.key)  ~\(.value.weight // 0)"),
    "", "SKILLS (à la carte):", (.skills|to_entries[]|"  \(.value.tag // "") \(.key)  ~\(.value.weight // 0)"),
    "", "PINNED (always on): \(.pinned|join(", "))"'
}

cmd_doctor() {
  echo "kogitsune doctor 🦊"
  for d in python3 jq claude fzf; do
    if command -v "$d" >/dev/null 2>&1; then echo "  ✔ $d"; else echo "  ✘ $d (missing)"; fi
  done
  python3 -c "import yaml" 2>/dev/null && echo "  ✔ PyYAML" || echo "  ✘ PyYAML (pip install pyyaml)"
  [[ -f "$CONFIG" ]] && echo "  ✔ config: $CONFIG" || echo "  ✘ config missing"
  [[ -f "$MCP_ON_DEMAND" ]] && echo "  ✔ mcp-on-demand: $MCP_ON_DEMAND" || echo "  • mcp-on-demand: none (inline defs only)"
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then echo "  ✔ auth: ANTHROPIC_API_KEY set (creds copy skipped)";
  elif security find-generic-password -s "Claude Code-credentials" -w >/dev/null 2>&1; then echo "  ✔ auth: keychain credentials readable";
  else echo "  ✘ auth: no API key and keychain unreadable — run 'claude /login'"; fi
  echo "  config validity:"; bc --list >/dev/null 2>&1 && echo "    ✔ parses" || echo "    ✘ parse error"
}

cmd_picker() {
  local FZF="${KOGITSUNE_FZF:-fzf}"
  command -v "$FZF" >/dev/null 2>&1 || die "missing dependency: fzf (needed for the picker; use 'kit <name>' instead)"
  need python3; need jq
  local list; list="$(bc --list)"
  local kits; kits="$(echo "$list" | jq -r '.kits|keys[]' | sed 's/^/kit:   /')"
  local mcp;  mcp="$(echo "$list" | jq -r '.mcp|to_entries[]|"mcp:   \(.value.tag // "") \(.key)"')"
  local skl;  skl="$(echo "$list" | jq -r '.skills|to_entries[]|"skill: \(.value.tag // "") \(.key)"')"
  echo "🦊 pinned (always on): $(echo "$list" | jq -r '.pinned|join(", ")')" >&2
  local pick key
  pick="$(printf '%s\n%s\n%s\n' "$kits" "$mcp" "$skl" | \
    "$FZF" --multi --prompt='pack › ' --height=60% --border --expect=ctrl-s \
        --header='space: toggle · enter: go · ctrl-s: save as kit · pick ONE kit:* or combine mcp:/skill:' )" || exit 0
  key="$(echo "$pick" | head -1)"           # first line is the --expect key (blank for enter)
  pick="$(echo "$pick" | tail -n +2)"
  [[ -z "$pick" ]] && exit 0
  # a chosen kit:* wins; otherwise gather à la carte mcp/skill selections
  local kitname; kitname="$(echo "$pick" | awk '/^kit:/{print $2; exit}')"
  local mcps skills
  mcps="$(echo "$pick" | awk '/^mcp:/{print $NF}' | paste -sd, -)"
  skills="$(echo "$pick" | awk '/^skill:/{print $NF}' | paste -sd, -)"
  if [[ "$key" == "ctrl-s" ]]; then
    local nm; printf 'save as kit name: ' >&2; read -r nm </dev/tty || exit 0
    [[ -z "$nm" ]] && exit 0
    cmd_save "$nm" --mcp "$mcps" --skills "$skills"
    return
  fi
  if [[ -n "$kitname" ]]; then cmd_launch "$kitname"; return; fi
  need claude
  local manifest; manifest="$(resolve_to_manifest --mcp "$mcps" --skills "$skills")"
  launch_from_manifest "$manifest"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    ""|pick|picker)        cmd_picker ;;
    ls|list)               cmd_ls ;;
    show)                  shift; cmd_show "$@" ;;
    save)                  shift; cmd_save "$@" ;;
    measure)               shift; cmd_measure "$@" ;;
    doctor)                cmd_doctor ;;
    help|-h|--help)        awk 'NR>1 && /^#/{sub(/^# ?/,"");print;next} NR>1{exit}' "$0" ;;
    *)
      # kit <name> [-- claude args]
      local kit="$cmd"; shift
      [[ "${1:-}" == "--" ]] && shift
      cmd_launch "$kit" "$@"
      ;;
  esac
}
main "$@"
