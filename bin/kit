#!/usr/bin/env bash
# kogitsune 🦊 — pack your kit, send the little fox off light.
# Usage:
#   kit                  interactive picker — tune a pack: toggle items on/off (fzf)
#   kit tune <name>      open the picker pre-loaded with kit <name>, then add/drop items
#   kit <name>           launch a named kit (lean|db|n8n|frontend|research|…)
#   kit <name> --dry-run resolve + show the plan, launch nothing
#   kit <name> -- ARGS   forward ARGS to `claude` (e.g. kit db -- --model opus "fix X")
#   kit ls               list kits + à la carte catalog
#   kit show <name>      show what a kit packs (no launch)
#   kit save <name> --mcp a,b --skills x,y [--model m]  save a selection as a named kit
#   kit rm <name>        remove a saved kit
#   kit measure <name>   launch a one-shot probe; record real ctx tokens
#   kit <name> --strict  refuse to launch if any reference is unresolved
#   kit doctor           check deps, config, auth
#   kit help
set -euo pipefail

HERE="$(cd "$(dirname "$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
LIB="$ROOT/lib"
# shellcheck source=lib/session-env.sh
source "$LIB/session-env.sh"

CONFIG="${KOGITSUNE_CONFIG:-}"
[[ -z "$CONFIG" && -f "$ROOT/kits.yaml" ]] && CONFIG="$ROOT/kits.yaml"
[[ -z "$CONFIG" && -f "./kits.yaml" ]] && CONFIG="./kits.yaml"
if [[ -z "$CONFIG" ]]; then
  CONFIG="$ROOT/examples/kits.example.yaml"
  echo "kit: no kits.yaml found — using examples/kits.example.yaml (copy it to kits.yaml to customize)" >&2
fi
MCP_ON_DEMAND="${KOGITSUNE_MCP_ON_DEMAND:-$HOME/.claude/mcp-on-demand.json}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/kogitsune"
STATE_FILE="$STATE_DIR/last-kits.json"

die() { echo "kit: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"; }
# auto-detect a project overlay (.kogitsune.yaml in cwd) merged over the base config.
# bash 3.2-safe: no mapfile; empty-array expansion guarded for `set -u`.
bc() {
  local ov=()
  [[ -f "./.kogitsune.yaml" ]] && ov=(--overlay "./.kogitsune.yaml")
  python3 "$LIB/build-config.py" --config "$CONFIG" --mcp-on-demand "$MCP_ON_DEMAND" \
    ${ov[@]+"${ov[@]}"} "$@"
}
ce() { python3 "$LIB/context-est.py" "$@"; }

remember_kit() {  # $1=kit
  mkdir -p "$STATE_DIR"
  local cwd; cwd="$(pwd)"
  local cur="{}"; [[ -f "$STATE_FILE" ]] && cur="$(cat "$STATE_FILE")"
  # atomic write (temp + mv) so concurrent launches can't corrupt the state file
  local tmp="$STATE_FILE.$$"
  if echo "$cur" | jq --arg k "$1" --arg d "$cwd" '.[$d] = $k' > "$tmp" 2>/dev/null; then
    mv -f "$tmp" "$STATE_FILE"
  else rm -f "$tmp"; fi
}

measured_for() {  # $1=kit -> echoes measured tokens, or empty
  jq -r --arg k "$1" '.[$k] // empty' "$STATE_DIR/measured.json" 2>/dev/null
}

pack_weight_line() {  # $1=manifest.json
  local w; w="$(jq -r '.weight' "$1")"
  ce --weights "$w"
}

# ---- launch a resolved selection -------------------------------------------
# $1 = manifest path (already written, with mcp_config_path), rest = claude args
launch_from_manifest() {
  local manifest="$1"; shift
  jq -e '.warnings|length>0' "$manifest" >/dev/null 2>&1 && \
    jq -r '.warnings[] | "kit: warning — \(.)"' "$manifest" >&2 || true
  local mcp_path seldir; mcp_path="$(jq -r '.mcp_config_path // empty' "$manifest")"
  seldir="$(dirname "$manifest")"   # the kogitsune.sel.* dir holding manifest + mcp.json
  # guard: never pass a missing/relative path to claude (which would resolve it against
  # cwd and emit a cryptic "MCP config file not found: <cwd>/<junk>"). Fail clearly instead.
  if [[ -z "$mcp_path" || ! -f "$mcp_path" ]]; then
    kog_cleanup "$seldir"
    die "internal: resolved MCP config not found (mcp_config_path='${mcp_path:-<empty>}', manifest=$manifest) — please report"
  fi
  echo "🦊 $(pack_weight_line "$manifest")" >&2
  # apply the kit/picker model, unless the user passes their own --model (which wins)
  local model user_model="" a; model="$(jq -r '.model // empty' "$manifest")"
  for a in "$@"; do [[ "$a" == "--model" || "$a" == --model=* ]] && user_model=1; done
  local model_args=() mstr=""
  if [[ -n "$model" && -z "$user_model" ]]; then
    model_args=(--model "$model"); mstr="--model $model "
    echo "🦊 model: $model" >&2
  fi
  if [[ -n "${KIT_DRY_RUN:-}" ]]; then
    jq -r '"would launch:  kit=\(.kit // "(à la carte)")  model=\(.model // "(default)")  "
           + "mcp=\(.mcp_config.mcpServers|keys|join(","))  "
           + "plugins=\(.plugins|keys|join(","))  skills=\(.skills|map(split("/")|last)|join(","))"' "$manifest" >&2
    echo "   claude ${mstr}--strict-mcp-config --mcp-config $mcp_path $*" >&2
    kog_cleanup "$seldir"
    return 0
  fi
  local mirror; mirror="$(kog_build_mirror "$manifest")"
  # NOTE: run claude as a CHILD (not exec) so the EXIT/INT/TERM trap actually fires —
  # exec would replace this shell and leak the mirror (incl. the creds file).
  trap 'kog_cleanup "$mirror"; kog_cleanup "$seldir"' EXIT INT TERM
  if [[ -n "${KIT_DEBUG:-}" ]]; then
    echo "kit: mirror=$mirror (KIT_DEBUG set — not auto-cleaned)" >&2
    trap - EXIT INT TERM
  fi
  local rc=0
  CLAUDE_CONFIG_DIR="$mirror" claude \
    ${model_args[@]+"${model_args[@]}"} --strict-mcp-config --mcp-config "$mcp_path" "$@" || rc=$?
  if [[ -z "${KIT_DEBUG:-}" ]]; then kog_cleanup "$mirror"; kog_cleanup "$seldir"; fi
  trap - EXIT INT TERM
  exit "$rc"
}

resolve_to_manifest() {  # writes manifest to a temp file, echoes its path. args: bc selection flags
  local out; out="$(mktemp -d "${TMPDIR:-/tmp}/kogitsune.sel.XXXXXX")" \
    || die "could not create a temp selection dir (TMPDIR=${TMPDIR:-/tmp})"
  # fail loudly if build-config errors, so we never hand a half-written manifest downstream
  if ! bc "$@" --out-dir "$out" > "$out/manifest.json"; then
    kog_cleanup "$out"; die "failed to resolve selection (build-config error)"
  fi
  echo "$out/manifest.json"
}

cmd_launch() {  # $1=kit name, rest=claude passthrough (supports --dry-run, --strict)
  local kit="$1"; shift || true
  local strict=""
  while [[ "${1:-}" == "--dry-run" || "${1:-}" == "--strict" ]]; do
    [[ "$1" == "--dry-run" ]] && export KIT_DRY_RUN=1
    [[ "$1" == "--strict" ]] && strict=1
    shift
  done
  need python3; need jq
  [[ -z "${KIT_DRY_RUN:-}" ]] && need claude
  local manifest; manifest="$(resolve_to_manifest "$kit")"
  if [[ -n "$strict" ]] && [[ "$(jq -r '.warnings|length' "$manifest")" != "0" ]]; then
    jq -r '.warnings[] | "kit: warning — \(.)"' "$manifest" >&2
    kog_cleanup "$(dirname "$manifest")"
    die "--strict: refusing to launch with unresolved warnings"
  fi
  [[ -z "${KIT_DRY_RUN:-}" ]] && remember_kit "$kit"
  launch_from_manifest "$manifest" "$@"
}

cmd_measure() {  # launch a one-shot probe under the kit's mirror, record real ctx tokens
  need python3; need jq; need claude
  local kit="${1:?usage: kit measure <name>}"
  local manifest; manifest="$(resolve_to_manifest "$kit")"
  local mcp_path est; mcp_path="$(jq -r '.mcp_config_path' "$manifest")"; est="$(jq -r '.weight' "$manifest")"
  echo "kit: measuring '$kit' — launching a one-shot probe…" >&2
  local mirror; mirror="$(kog_build_mirror "$manifest")"
  trap 'kog_cleanup "$mirror"' EXIT INT TERM
  local out; out="$(CLAUDE_CONFIG_DIR="$mirror" claude -p --output-format=json --model haiku \
      'Reply with exactly: PONG' --strict-mcp-config --mcp-config "$mcp_path" 2>/dev/null)"
  kog_cleanup "$mirror"; trap - EXIT INT TERM
  local ctx; ctx="$(echo "$out" | jq -r '((.usage.input_tokens//0)+(.usage.cache_creation_input_tokens//0)+(.usage.cache_read_input_tokens//0))')"
  if ! [[ "$ctx" =~ ^[0-9]+$ ]] || [[ "$ctx" -eq 0 ]]; then
    echo "kit: measure failed — $(echo "$out" | jq -r '.result // "no output"')" >&2; return 1
  fi
  mkdir -p "$STATE_DIR"
  local mf="$STATE_DIR/measured.json" cur="{}"; [[ -f "$mf" ]] && cur="$(cat "$mf")"
  local tmp="$mf.$$"
  if echo "$cur" | jq --arg k "$kit" --argjson c "$ctx" '.[$k]=$c' > "$tmp" 2>/dev/null; then
    mv -f "$tmp" "$mf"; else rm -f "$tmp"; fi
  echo "🦊 kit '$kit':  measured = ${ctx} tokens   (catalog est ~${est} over the lean baseline)"
  echo "   recorded to $mf"
}

# resolve the file we may write kits into; seed from the example if needed
save_target() {
  if [[ -n "${KOGITSUNE_CONFIG:-}" ]]; then echo "$KOGITSUNE_CONFIG"; return; fi
  if [[ "$CONFIG" == *examples/kits.example.yaml ]]; then
    local t="./kits.yaml"
    [[ -f "$t" ]] || { cp "$CONFIG" "$t"; echo "kit: created $t from the example" >&2; }
    echo "$t"
  else echo "$CONFIG"; fi
}

cmd_save() {  # kit save <name> [--mcp a,b] [--skills x,y]
  need python3
  local name="${1:?usage: kit save <name> [--mcp a,b] [--skills x,y] [--model m]}"; shift
  local mcp="" skills="" model=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mcp) mcp="$2"; shift 2;; --skills) skills="$2"; shift 2;;
      --model) model="$2"; shift 2;; *) shift;;
    esac
  done
  local target; target="$(save_target)"
  python3 "$LIB/build-config.py" --config "$target" --save "$name" \
    --mcp "$mcp" --skills "$skills" --model "$model"
  echo "🦊 saved kit '$name' — launch it with: kit $name" >&2
}

cmd_rm() {
  need python3
  local name="${1:?usage: kit rm <name>}"
  local target; target="$(save_target)"
  python3 "$LIB/build-config.py" --config "$target" --rm "$name"
}

cmd_show() {
  need python3
  local kit="${1:?usage: kit show <name>}"
  local m; m="$(bc "$kit" --dry-run)"
  echo "$m" | jq '{kit, model, weight, mcp: (.mcp_config.mcpServers|keys),
       plugins: (.plugins|keys), skills: (.skills|map(split("/")|last)),
       imports: (.imports|map(split("/")|last)), warnings}'
  # human pack-weight line goes to stderr so stdout stays valid JSON for piping
  local line; line="🦊 $(echo "$m" | jq -r .weight | xargs -I{} python3 "$LIB/context-est.py" --weights {})"
  local meas; meas="$(measured_for "$kit")"
  [[ -n "$meas" ]] && line="$line   · measured ${meas} tok"
  echo "$line" >&2
}

cmd_ls() {
  need python3
  local meas="{}"; [[ -f "$STATE_DIR/measured.json" ]] && meas="$(cat "$STATE_DIR/measured.json")"
  bc --list | jq -r --argjson m "$meas" '
    .kit_info as $ki |
    "KITS:", (.kits|to_entries[]| "  \(.key)"
       + (($ki[.key].model // "") as $md | if $md != "" then "  [\($md)]" else "" end)
       + (($m[.key]) as $x | if $x then "  (measured ~\($x) tok)" else "" end)),
    "", "MCP (à la carte):", (.mcp|to_entries[]|"  \(.value.tag // "") \(.key)  ~\(.value.weight // 0)"),
    "", "SKILLS (à la carte):", (.skills|to_entries[]|"  \(.value.tag // "") \(.key)  ~\(.value.weight // 0)"),
    "", "PINNED (always on): \(.pinned|join(", "))"'
}

cmd_doctor() {
  echo "kogitsune doctor 🦊"
  for d in python3 jq claude fzf; do
    if command -v "$d" >/dev/null 2>&1; then echo "  ✔ $d"; else echo "  ✘ $d (missing)"; fi
  done
  python3 -c "import yaml" 2>/dev/null && echo "  ✔ PyYAML" || echo "  ✘ PyYAML (pip install pyyaml)"
  [[ -f "$CONFIG" ]] && echo "  ✔ config: $CONFIG" || echo "  ✘ config missing"
  [[ -f "$MCP_ON_DEMAND" ]] && echo "  ✔ mcp-on-demand: $MCP_ON_DEMAND" || echo "  • mcp-on-demand: none (inline defs only)"
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then echo "  ✔ auth: ANTHROPIC_API_KEY set (creds copy skipped)";
  elif security find-generic-password -s "Claude Code-credentials" -w >/dev/null 2>&1; then echo "  ✔ auth: keychain credentials readable";
  else echo "  ✘ auth: no API key and keychain unreadable — run 'claude /login'"; fi
  echo "  config validity:"; bc --list >/dev/null 2>&1 && echo "    ✔ parses" || echo "    ✘ parse error"
}

# ---- pack tuning (state-file driven picker) --------------------------------
# fzf can't pre-check its own multi-select rows, so pack membership lives in a
# state file and the picker re-renders the ✔/○ glyphs + weight bar on each toggle
# via reload+refresh-preview. This lets a kit act as a loadable preset whose
# items you then add to / drop individually. Session files under a kogitsune.tune.* dir:
#   list.json  = cached `bc --list` (catalog + resolved kit_info)
#   state.json = {"mcp":[...],"skills":[...]} — the current pack membership

tune_total() {  # $1=tunedir -> echo summed weight of the in-pack catalog items
  jq -r --slurpfile s "$1/state.json" '
    ($s[0].mcp // []) as $m | ($s[0].skills // []) as $k |
    [ (.mcp    | to_entries[] | select(.key as $x | $m | index($x)) | .value.weight // 0),
      (.skills | to_entries[] | select(.key as $x | $k | index($x)) | .value.weight // 0)
    ] | add // 0' "$1/list.json"
}

# presets visibility: a "0" in $d/presets hides the 🦊 kit rows (ctrl-p in the picker).
tune_presets_shown() { [[ "$(cat "$1/presets" 2>/dev/null)" != "0" ]]; }

# fzf reload source: TSV rows with a live ✔/○ glyph reflecting current membership.
cmd_tune_rows() {  # $1=tunedir
  local d="$1" show=true
  tune_presets_shown "$d" || show=false
  jq -r --slurpfile s "$d/state.json" --argjson show "$show" '
    def pad($n): (. + "                    ")[0:$n];
    ($s[0].mcp // []) as $m | ($s[0].skills // []) as $k |
    def member($kind;$name): (if $kind=="mcp" then ($m|index($name)) else ($k|index($name)) end) != null;
    def glyph($b): if $b then "✔" else "○" end;
    ( ($m|length) + ($k|length) ) as $packsize |
    (if $show then ( .kit_info | to_entries[]
      | (((.value.mcp|length) + (.value.skills|length)) > 0) as $nonempty
      | (((.value.mcp - $m | length)==0 and (.value.skills - $k | length)==0) and ($nonempty or $packsize==0)) as $on
      | "\(glyph($on)) 🦊 \(.key|pad(13))  ~\((.value.weight/1000)|floor)K  preset\tkit\t\(.key)\t\(.value.weight)" ) else empty end),
    ( .mcp | to_entries[]
      | "\(glyph(member("mcp";.key))) \((.value.tag // "•")) \(.key|pad(14))  ~\((.value.weight//0)/1000|floor)K  (mcp)\tmcp\t\(.key)\t\(.value.weight // 0)" ),
    ( .skills | to_entries[]
      | "\(glyph(member("skill";.key))) \((.value.tag // "•")) \(.key|pad(14))  ~\((.value.weight//0)/1000|floor)K  (skill)\tskill\t\(.key)\t\(.value.weight // 0)" )
  ' "$d/list.json"
}

# Flip preset-row visibility (ctrl-p). Atomic-ish single-byte write.
cmd_tune_presets() {  # $1=tunedir
  if tune_presets_shown "$1"; then echo 0 > "$1/presets"; else echo 1 > "$1/presets"; fi
}

# Cycle the picker's model override (ctrl-o): default → sonnet → opus → haiku → default
cmd_tune_model() {  # $1=tunedir
  local cur next; cur="$(cat "$1/model" 2>/dev/null || true)"
  case "$cur" in
    "")       next="sonnet" ;;
    sonnet)   next="opus" ;;
    opus)     next="haiku" ;;
    *)        next="" ;;
  esac
  echo "$next" > "$1/model"
}

# Flip one item's membership. A kit row loads its preset (union-add), or drops it
# wholesale if every one of its items is already in the pack. Atomic write.
cmd_tune_toggle() {  # $1=tunedir $2=kind $3=name
  local d="$1" kind="$2" name="$3" tmp
  tmp="$d/state.json.$$"
  case "$kind" in
    mcp|skill)
      local key="mcp"; [[ "$kind" == "skill" ]] && key="skills"
      if jq --arg n "$name" --arg key "$key" \
          'if (.[$key] | index($n)) then .[$key] -= [$n] else .[$key] += [$n] end' \
          "$d/state.json" > "$tmp" 2>/dev/null; then mv -f "$tmp" "$d/state.json"; else rm -f "$tmp"; fi
      ;;
    kit)
      if jq --slurpfile l "$d/list.json" --arg k "$name" '
        ($l[0].kit_info[$k] // {mcp:[],skills:[]}) as $kit |
        (($kit.mcp|length) + ($kit.skills|length)) as $size |
        (($kit.mcp - .mcp | length)==0 and ($kit.skills - .skills | length)==0) as $full |
        if $size==0 then {mcp:[], skills:[]}                       # empty preset (lean) = reset
        elif $full
        then .mcp = (.mcp - $kit.mcp) | .skills = (.skills - $kit.skills)
        else .mcp = (.mcp + ($kit.mcp - .mcp)) | .skills = (.skills + ($kit.skills - .skills)) end
      ' "$d/state.json" > "$tmp" 2>/dev/null; then mv -f "$tmp" "$d/state.json"; else rm -f "$tmp"; fi
      ;;
  esac
}

# fzf preview pane: live weight bar + the tuned pack contents.
cmd_tune_preview() {  # $1=tunedir
  local d="$1" total; total="$(tune_total "$d")"
  echo "🦊 pack your kit"
  echo
  python3 "$LIB/context-est.py" --weights "$total" --width 24
  echo
  local mdl; mdl="$(cat "$d/model" 2>/dev/null || true)"
  echo "model:  ${mdl:-default}   (ctrl-o cycles)"
  echo
  local mcps skills
  mcps="$(jq -r '.mcp|join(" ")' "$d/state.json")"
  skills="$(jq -r '.skills|join(" ")' "$d/state.json")"
  [[ -n "$mcps"   ]] && echo "mcp:    $mcps"
  [[ -n "$skills" ]] && echo "skills: $skills"
  [[ -z "$mcps$skills" ]] && echo "(lean — pinned only)"
  echo
  if tune_presets_shown "$d"; then
    echo "space/tab toggles · a 🦊 kit row loads its preset · ctrl-p hides presets"
  else
    echo "space/tab toggles · ctrl-p shows 🦊 preset rows"
  fi
  echo "pinned (always): memory · guardrails · graphify"
}

cmd_picker() {  # $1 = optional base kit to seed the pack with
  local FZF="${KOGITSUNE_FZF:-fzf}"
  command -v "$FZF" >/dev/null 2>&1 || die "missing dependency: fzf (needed for the picker; use 'kit <name>' instead)"
  need python3; need jq
  local self="$ROOT/bin/kit"
  local d; d="$(mktemp -d "${TMPDIR:-/tmp}/kogitsune.tune.XXXXXX")"
  trap 'kog_cleanup "$d"' EXIT INT TERM
  bc --list > "$d/list.json"
  # seed membership + model from a base kit if named, else start from scratch (pinned only)
  if [[ -n "${1:-}" ]]; then
    jq --arg k "$1" '.kit_info[$k] // {mcp:[],skills:[]} | {mcp:(.mcp//[]), skills:(.skills//[])}' \
      "$d/list.json" > "$d/state.json"
    jq -r --arg k "$1" '.kit_info[$k].model // empty' "$d/list.json" > "$d/model"
  else
    echo '{"mcp":[],"skills":[]}' > "$d/state.json"
    : > "$d/model"
  fi
  echo 1 > "$d/presets"   # preset 🦊 rows visible by default (ctrl-p toggles)
  # space/tab flip the focused item, then reload the rows (updated glyphs) + refresh the bar
  local toggle="execute-silent($self __tune_toggle $d {2} {3})+reload($self __tune_rows $d)+refresh-preview"
  local flip="execute-silent($self __tune_presets $d)+reload($self __tune_rows $d)+refresh-preview"
  local cycle="execute-silent($self __tune_model $d)+refresh-preview"   # ctrl-m == enter, so ctrl-o
  local pick key
  pick="$("$self" __tune_rows "$d" | \
    "$FZF" --ansi --delimiter='\t' --with-nth=1 --nth=1 --track --id-nth=2,3 \
        --prompt='pack › ' --height=85% --border --reverse \
        --expect=ctrl-s \
        --header=$'space/tab toggle · 🦊 row loads a preset · ctrl-o model · ctrl-p hide presets · enter launch · ctrl-s save · 🧠 🛡 🕸 always ride along' \
        --bind="space:$toggle" --bind="tab:$toggle" --bind="ctrl-p:$flip" --bind="ctrl-o:$cycle" \
        --preview="$self __tune_preview $d" --preview-window='right:48%:wrap' )" \
    || { kog_cleanup "$d"; trap - EXIT INT TERM; exit 0; }
  key="$(printf '%s\n' "$pick" | head -1)"        # first line is the --expect key (blank for enter)
  # the state file — not fzf's output — is the source of truth for the tuned pack
  local mcps skills mdl
  mcps="$(jq -r '.mcp|join(",")' "$d/state.json")"
  skills="$(jq -r '.skills|join(",")' "$d/state.json")"
  mdl="$(cat "$d/model" 2>/dev/null || true)"
  kog_cleanup "$d"; trap - EXIT INT TERM
  if [[ "$key" == "ctrl-s" ]]; then
    local nm; printf 'save as kit name: ' >&2; read -r nm </dev/tty || exit 0
    [[ -z "$nm" ]] && exit 0
    cmd_save "$nm" --mcp "$mcps" --skills "$skills" --model "$mdl"
    return
  fi
  [[ -z "${KIT_DRY_RUN:-}" ]] && need claude
  local manifest; manifest="$(resolve_to_manifest --mcp "$mcps" --skills "$skills" --model "$mdl")"
  launch_from_manifest "$manifest"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    "")                    cmd_picker ;;
    pick|picker|tune)      shift; cmd_picker "$@" ;;
    ls|list)               cmd_ls ;;
    show)                  shift; cmd_show "$@" ;;
    save)                  shift; cmd_save "$@" ;;
    rm|remove)             shift; cmd_rm "$@" ;;
    measure)               shift; cmd_measure "$@" ;;
    doctor)                cmd_doctor ;;
    help|-h|--help)        awk 'NR>1 && /^#/{sub(/^# ?/,"");print;next} NR>1{exit}' "$0" ;;
    __kits)                bc --list 2>/dev/null | jq -r '.kits|keys[]' 2>/dev/null ;;
    __commands)            printf '%s\n' ls show save rm measure tune doctor help ;;
    __tune_rows)           shift; cmd_tune_rows "$@" ;;
    __tune_toggle)         shift; cmd_tune_toggle "$@" ;;
    __tune_presets)        shift; cmd_tune_presets "$@" ;;
    __tune_model)          shift; cmd_tune_model "$@" ;;
    __tune_preview)        shift; cmd_tune_preview "$@" ;;
    *)
      # kit <name> [-- claude args]
      local kit="$cmd"; shift
      [[ "${1:-}" == "--" ]] && shift
      cmd_launch "$kit" "$@"
      ;;
  esac
}
main "$@"
